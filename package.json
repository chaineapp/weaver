{
  "name": "weaver",
  "version": "0.3.0",
  "private": true,
  "description": "Coding agent orchestrator. A Bun CLI that spawns Codex workers in tmux-under-Ghostty and exposes them to a planner Claude via MCP.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chaineapp/weaver.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test",
    "build": "bun --filter '*' build",
    "weave": "bun run packages/cli/src/index.ts",
    "eval": "WEAVER_RUN_EVALS=1 bun test packages/cli/test/e2e/",
    "prepush": "bun test && bun run eval",
    "install-hooks": "bash scripts/install-hooks.sh"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
